---
import { getCollection, render, type CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import MainGridLayout from "@/layouts/MainGridLayout.astro";

export async function getStaticPaths() {
	const projectEntries = (await getCollection("projects")).filter(
		(project) => !project.data.draft,
	);

	return projectEntries.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props as { project: CollectionEntry<"projects"> };
const { Content } = await render(project);
const formatDate = (date: Date) => date.toISOString().slice(0, 10);
---

<MainGridLayout title={project.data.name} description={project.data.description}>
	<section class="card-base overflow-hidden rounded-(--radius-large)">
		<div class="relative px-7 py-7 sm:px-9 sm:py-8">
			<div class="absolute top-0 left-0 h-full w-1.5 bg-(--primary)"></div>

			<a href="/projects/" class="mb-5 inline-flex items-center gap-2 text-sm font-medium text-(--primary)">
				<Icon name="material-symbols:arrow-back-rounded" />
				返回项目列表
			</a>

			<div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
				<div class="min-w-0">
					<div class="mb-3 flex flex-wrap items-center gap-3">
						<span class="inline-flex items-center gap-1.5 rounded-full bg-(--btn-regular-bg) px-3 py-1 text-sm text-(--primary)">
							<Icon name="material-symbols:construction-rounded" class="text-lg" />
							项目实践
						</span>
						<span class="inline-flex items-center gap-1.5 rounded-full bg-(--btn-regular-bg) px-3 py-1 text-sm text-neutral-500 dark:text-neutral-400">
							<Icon name="material-symbols:update-rounded" class="text-lg" />
							更新于 {formatDate(project.data.updated)}
						</span>
					</div>

					<h1 class="text-3xl font-bold leading-tight text-neutral-900 sm:text-4xl dark:text-neutral-50">
						{project.data.name}
					</h1>
					<p class="mt-2 text-lg font-medium text-neutral-600 dark:text-neutral-300">
						{project.data.subtitle}
					</p>
					<p class="mt-5 max-w-4xl text-base leading-8 text-neutral-600 dark:text-neutral-300">
						{project.data.description}
					</p>
					{project.data.repositoryUrl && (
						<a
							href={project.data.repositoryUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="mt-5 inline-flex items-center gap-2 rounded-xl bg-(--primary) px-4 py-2 font-medium text-white transition hover:opacity-90"
						>
							<Icon name="fa7-brands:github" />
							查看 GitHub 仓库
						</a>
					)}
				</div>

				<div class="w-full shrink-0 rounded-3xl bg-(--btn-regular-bg) p-5 lg:w-64">
					<div class="mb-3 flex items-center justify-between">
						<span class="text-sm text-neutral-500 dark:text-neutral-400">当前状态</span>
						<span class="rounded-full bg-(--primary) px-3 py-1 text-sm font-semibold text-white">
							{project.data.status}
						</span>
					</div>
					<div class="mb-2 flex items-end justify-between">
						<span class="text-sm text-neutral-500 dark:text-neutral-400">阶段进度</span>
						<span class="text-2xl font-bold text-(--primary)">{project.data.progress}%</span>
					</div>
					<div class="h-3 overflow-hidden rounded-full bg-white/70 dark:bg-black/20">
						<div class="h-full rounded-full bg-(--primary)" style={`width: ${project.data.progress}%`}></div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="mt-6 card-base rounded-(--radius-large) p-7 sm:p-9">
		<div class="space-y-12 text-[1.05rem] leading-9 text-neutral-700 dark:text-neutral-300">
			<div>
				<h2 class="mb-6 text-2xl font-bold text-neutral-900 sm:text-3xl dark:text-neutral-50">
					项目描述
				</h2>
				<p>{project.data.projectDescription}</p>
			</div>

			<div>
				<h2 class="mb-6 text-2xl font-bold text-neutral-900 sm:text-3xl dark:text-neutral-50">
					主要工作
				</h2>
				<ul class="list-disc space-y-3 pl-6 marker:text-neutral-400">
					{project.data.mainWork.map((item) => (
						<li>{item}</li>
					))}
				</ul>
			</div>

			<div>
				<h2 class="mb-6 text-2xl font-bold text-neutral-900 sm:text-3xl dark:text-neutral-50">
					项目成果
				</h2>
				<p>{project.data.projectResult}</p>
			</div>
		</div>
	</section>

	<section class="mt-6 card-base rounded-(--radius-large) p-7 sm:p-9">
		<div class="prose prose-neutral max-w-none dark:prose-invert">
			<Content />
		</div>
	</section>

	<section class="mt-6 grid gap-5 lg:grid-cols-2">
		<div class="card-base rounded-(--radius-large) p-7">
			<h2 class="mb-5 flex items-center gap-2 text-2xl font-bold">
				<Icon name="material-symbols:check-circle-rounded" class="text-(--primary)" />
				已完成能力
			</h2>
			<ul class="space-y-3 text-neutral-600 dark:text-neutral-300">
				{project.data.highlights.map((item) => (
					<li class="flex gap-3">
						<span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-(--primary)"></span>
						<span>{item}</span>
					</li>
				))}
			</ul>
		</div>

		<div class="card-base rounded-(--radius-large) p-7">
			<h2 class="mb-5 flex items-center gap-2 text-2xl font-bold">
				<Icon name="material-symbols:school-rounded" class="text-(--primary)" />
				训练方向
			</h2>
			<div class="flex flex-wrap gap-2">
				{project.data.skills.map((skill) => (
					<span class="rounded-xl bg-(--btn-regular-bg) px-3 py-2 text-sm font-medium text-neutral-600 dark:text-neutral-300">
						{skill}
					</span>
				))}
			</div>
		</div>
	</section>

	<section class="mt-6 grid gap-5 xl:grid-cols-2">
		{project.data.completedStages.map((stage) => (
			<div class="card-base rounded-(--radius-large) p-7">
				<h2 class="mb-5 text-2xl font-bold">{stage.name}</h2>
				<ul class="space-y-3 text-neutral-600 dark:text-neutral-300">
					{stage.items.map((item) => (
						<li class="flex gap-3">
							<Icon name="material-symbols:done-rounded" class="mt-0.5 shrink-0 text-xl text-(--primary)" />
							<span>{item}</span>
						</li>
					))}
				</ul>
			</div>
		))}
	</section>

	<section class="mt-6 card-base rounded-(--radius-large) p-7">
		<h2 class="mb-5 flex items-center gap-2 text-2xl font-bold">
			<Icon name="material-symbols:rocket-launch-rounded" class="text-(--primary)" />
			下一阶段计划
		</h2>
		<div class="grid gap-4 md:grid-cols-3">
			{project.data.nextStages.map((stage, index) => (
				<div class="rounded-2xl bg-(--btn-regular-bg) p-5">
					<div class="mb-3 flex h-9 w-9 items-center justify-center rounded-full bg-(--primary) font-bold text-white">
						{index + 3}
					</div>
					<p class="leading-7 text-neutral-600 dark:text-neutral-300">{stage}</p>
				</div>
			))}
		</div>
	</section>
</MainGridLayout>
